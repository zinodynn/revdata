# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/revdata

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# JWT 配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# 调试模式
DEBUG=true

# ============================================
# Embedding API 配置（系统级默认）
# ============================================
# 可选：配置 embedding API 服务地址和密钥
# 如果配置了，用户可以在去重设置中选择使用 embedding 去重
# 如果未配置，则只能使用文本相似度去重

EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_BATCH_SIZE=8
EMBEDDING_CONCURRENCY=1

# ============================================
# 去重配置（系统级默认）
# ============================================
# DEDUP_ENABLED_BY_DEFAULT: 是否在系统级启用去重（不影响已配置的数据集）
# DEDUP_USE_EMBEDDING_BY_DEFAULT: 是否默认使用 embedding 去重（需要上面的 EMBEDDING_API_URL）
# DEDUP_SIMILARITY_THRESHOLD: 去重相似度阈值 (0-1)
# DEDUP_QUERY_FIELD: 用于去重比较的字段名

DEDUP_ENABLED_BY_DEFAULT=true
DEDUP_USE_EMBEDDING_BY_DEFAULT=true
DEDUP_SIMILARITY_THRESHOLD=0.8
DEDUP_QUERY_FIELD=question